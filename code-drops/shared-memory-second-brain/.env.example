# Second Brain — config (all optional; keyword recall runs with NO keys)

# PORT=3008
# MEMORY_FILE=./second-brain.json
# CLEAR_TOKEN=               # if set, POST /clear requires header  x-clear-token

# ── Optional: semantic recall via an embeddings API ───────────────
# Any OpenAI-compatible /embeddings endpoint. Leave unset for keyword recall.
#   OpenAI:  EMBED_BASE_URL=https://api.openai.com/v1   EMBED_MODEL=text-embedding-3-small
#   Local:   EMBED_BASE_URL=http://127.0.0.1:11434/v1   EMBED_MODEL=nomic-embed-text  (Ollama)
# EMBED_API_KEY=
# EMBED_BASE_URL=
# EMBED_MODEL=
