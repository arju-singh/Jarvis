# Jarvis Command Center — config (all optional; runs with NO keys via the demo brain)
# Copy to .env and fill in to upgrade from the demo brain to a real LLM.

# AGENT_NAME=JARVIS
# PORT=3005
# TTS=say            # macOS "say" voice; "off" to disable spoken replies

# ── Real LLM (any OpenAI-compatible endpoint) ─────────────────────
# Works with OpenAI, Groq, OpenRouter, Together, local Ollama, etc.
# Pick ONE provider's base URL + model, paste your own free key:
#
#  Groq (fast, free):  https://console.groq.com
#    LLM_BASE_URL=https://api.groq.com/openai/v1
#    LLM_MODEL=llama-3.3-70b-versatile
#
#  OpenRouter:         https://openrouter.ai/keys
#    LLM_BASE_URL=https://openrouter.ai/api/v1
#    LLM_MODEL=meta-llama/llama-3.3-70b-instruct
#
#  Local Ollama:       https://ollama.com  (ollama serve)
#    LLM_BASE_URL=http://127.0.0.1:11434/v1
#    LLM_MODEL=qwen2.5         # (no key needed for local)
#
# LLM_API_KEY=
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
