{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": false,
    "sourceMap": true
  },
  "include": ["server.ts", "types.ts", "mcp-bridge.ts", "memory.ts", "mode.ts", "preflight.ts", "tools/**/*.ts", "providers/**/*.ts"]
}
