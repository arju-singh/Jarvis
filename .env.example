# ── Brain (Node/TS) ───────────────────────────────────────────────
# Copy to .env and fill in. The brain crashes loudly if a required key is missing.

# Mode: online (cloud) | offline (local) | auto (probe internet at boot).
JARVIS_MODE=auto

# Provider overrides (optional) — pick the brain/voice regardless of mode:
#   JARVIS_BRAIN = claude | gemini | ollama
#   JARVIS_TTS   = elevenlabs | piper | say   (say = macOS built-in, no install)
# JARVIS_BRAIN=gemini
# JARVIS_TTS=say

# Gemini brain (free tier). Key from https://aistudio.google.com/apikey (starts with AIza…)
GEMINI_API_KEY=
JARVIS_GEMINI_MODEL=gemini-2.0-flash

# macOS `say` voice (optional). List options with:  say -v '?'
# JARVIS_SAY_VOICE=Daniel

# ── ONLINE brain + voice ──────────────────────────────────────────
# Claude — the reasoning + tool-calling engine. (https://console.anthropic.com)
ANTHROPIC_API_KEY=
# Optional model override. claude-sonnet-4-6 is fast enough for voice.
JARVIS_MODEL=claude-sonnet-4-6

# ── OFFLINE brain + voice (no internet) ───────────────────────────
# Ollama brain — install from https://ollama.com, then: ollama pull qwen2.5
JARVIS_OLLAMA_URL=http://127.0.0.1:11434
JARVIS_OLLAMA_MODEL=qwen2.5
# Piper TTS — download a voice .onnx (see setup-offline.md). Blank until you have one.
PIPER_BIN=piper
# Example: PIPER_MODEL=/Users/arju/Desktop/JarvisArju/voices/en_US-amy-medium.onnx
PIPER_MODEL=

# ElevenLabs — the voice. (https://elevenlabs.io  → Voices → copy a Voice ID)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Your name, used in Jarvis's system prompt.
JARVIS_USER=Arju

# Sandbox for desktop file/shell tools. Jarvis cannot read/write outside this.
JARVIS_WORKDIR=/Users/arju/Desktop/JarvisArju/workspace

# Port the brain listens on (ears POST transcripts here).
JARVIS_PORT=8787

# Web search (optional). Free key: https://brave.com/search/api
# Weather works without any key (Open-Meteo). Search fails only if asked without this.
BRAVE_API_KEY=

# Generic projects MCP server — path to your Firestore service-account JSON.
# Leave blank until you have the key (Firestore tools just stay inactive).
# Example: PROJECTS_SA_KEY=/Users/arju/Desktop/JarvisArju/secrets/firestore-service-account.json
PROJECTS_SA_KEY=

# (Optional) standalone petsacre server, if you use it instead of the generic one.
# Example: PETSACRE_SA_KEY=/Users/arju/Desktop/JarvisArju/secrets/petsacre-service-account.json
PETSACRE_SA_KEY=

# ── v4 long-term memory (toggleable) ──────────────────────────────
# Off by default. Set to on/true/1 to let Jarvis remember facts across sessions.
JARVIS_MEMORY=off
# Where memories are stored (local JSON file).
JARVIS_MEMORY_FILE=/Users/arju/Desktop/JarvisArju/jarvis-memory.json

# v3 always-on listening isn't a brain setting — it's which ears script you run:
#   python jarvis_ears.py   (wake word, always-on)   vs   python jarvis_ptt.py (push-to-talk)

# Audio player for TTS playback (needs ffmpeg/ffplay installed).
#   macOS:  brew install ffmpeg
JARVIS_AUDIO_PLAYER=ffplay -autoexit -nodisp -loglevel quiet

# ── Ears (Python) — set in the shell that runs jarvis_ears.py ──────
# BRAIN_URL=http://127.0.0.1:8787/turn
# WHISPER_MODEL=large-v3      # or "small"/"medium" on CPU for speed
# WHISPER_DEVICE=cpu          # "cuda" if you have an NVIDIA GPU
# WHISPER_COMPUTE=int8
# WHISPER_LANG=               # blank = auto-detect (handles Hinglish)
# WAKE_THRESHOLD=0.5          # wake-word sensitivity (0-1)
# BARGEIN_VAD_THRESHOLD=0.6   # raise toward 0.8 if speakers self-trigger barge-in
